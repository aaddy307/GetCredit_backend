PORT=5000

# Must match your deployed frontend URL (e.g. https://get-credit.in)
APP_URL=http://localhost:3000

# MongoDB connection string
MONGO_URI=mongodb://localhost:27017/getcredit

# JWT secret - use a strong random string (64+ chars)
# Generate with: openssl rand -hex 32
JWT_SECRET=change_me_to_a_strong_random_string

# Admin email for notifications
ADMIN_EMAIL=support@example.com

# Resend API key for email sending
RESEND_API_KEY=re_xxxxxxxxxxxx

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# Seed admin password (used by npm run seed)
SEED_ADMIN_PASSWORD=Admin@123456
